#!/usr/bin/bash

clear
cat <<'.'
 ______   _______  _______  _______  ___   ___      _______  _______ 
|      | |       ||       ||       ||   | |   |    |       ||       |
|  _    ||   _   ||_     _||    ___||   | |   |    |    ___||  _____|
| | |   ||  | |  |  |   |  |   |___ |   | |   |    |   |___ | |_____ 
| |_|   ||  |_|  |  |   |  |    ___||   | |   |___ |    ___||_____  |
|       ||       |  |   |  |   |    |   | |       ||   |___  _____| |
|______| |_______|  |___|  |___|    |___| |_______||_______||_______|
.
printf "                                                      made by arsyhiy\n"
printf "\n"
printf "=======================================================================\n"

cp flags.env.template flags.env 

FLAGS="flags.env"
source "$FLAGS"

LOG_FILE="${LOG_FILE:-packages.log}"
> "$LOG_FILE"

set_flag_value() {
    local flag="$1"
    local value="$2"
    local file="${FLAGS:-flags.env}"

    if grep -q "^$flag=" "$file"; then
        sed -i "s|^$flag=.*|$flag=$value|" "$file"
    else
        echo "$flag=$value" >> "$file"
    fi
}

any_flag_is_false() {
    source "$FLAGS"
    for flag in INSTALL_PACKAGES CONFIG_DONE; do
        if [[ "${!flag}" == "false" ]]; then
            return 0
        fi
    done
    return 1
}

# need more helpfull name
while any_flag_is_false; do
    source "$CONFIG"

    if [[ "$INSTALL" == "false" ]]; then
        echo "Installing Debian packages..."
        if ./install.sh; then
            set_flag_value INSTALL true
        else
            echo "Error installing Debian packages" | tee -a "$LOG_FILE"
            set_flag_value INSTALL error
        fi
    elif [[ "$INSTALL" == "error" ]]; then
        echo "Skipping Debian packages (previous error)" | tee -a "$LOG_FILE"
    fi

    # config
    if [[ "$CONFIG_DONE" == "false" ]]; then
        echo "config is configin"
        if ./config.sh; then
            set_flag_value CONFIG_DONE true
        else
            echo "Error config" | tee -a "$LOG_FILE"
            set_flag_value CONFIG_DONE error
        fi
    elif [[ "$CONFIG_DONE" == "error" ]]; then
        echo "Skipping config (previous error)" | tee -a "$LOG_FILE"
    fi

    # every thing else
    if [[ "$OTHER" == "false" ]]; then
        echo "other thing goes"
        if ./other.sh; then
            set_flag_value OTHER true
        else
            echo "Error others" | tee -a "$LOG_FILE"
            set_flag_value OTHER error
        fi
    elif [[ "$OTHER" == "error" ]]; then
        echo "Skipping other (previous error)" | tee -a "$LOG_FILE"
    fi

done

echo "Setup finished. Check $LOG_FILE for details."
